theme = Alabaster
font-family = Geist Mono
font-style = Regular
macos-option-as-alt = true

# alt because I use cmd-key-happy to swap cmd and option
# Could use esc:CHAR instead of text:ESCAPE here.
keybind = alt+a=text:\x1ba
keybind = alt+b=text:\x1bb
keybind = alt+c=text:\x1bc
keybind = alt+d=text:\x1bd
keybind = alt+e=text:\x1be
keybind = alt+f=text:\x1bf
keybind = alt+g=text:\x1bg
keybind = alt+h=text:\x1bh
keybind = alt+i=text:\x1bi
keybind = alt+j=text:\x1bj
keybind = alt+k=text:\x1bk
keybind = alt+l=text:\x1bl
keybind = alt+m=text:\x1bm
keybind = alt+n=text:\x1bn
keybind = alt+o=text:\x1bo
keybind = alt+p=text:\x1bp
keybind = alt+q=text:\x1bq
keybind = alt+s=text:\x1bs
keybind = alt+t=text:\x1bt
keybind = alt+u=text:\x1bu
keybind = alt+v=text:\x1bv
keybind = alt+w=text:\x1bw
keybind = alt+x=text:\x1bx
keybind = alt+y=text:\x1by
keybind = alt+z=text:\x1bz

# Paredit bindings
keybind = alt+[=text:\x1b\x28
keybind = alt+]=text:\x1b\x29

# macos-option-as-alt seemed to fix these, but I'm leaving them commented here so I remember how to do it.
#keybind = alt+shift+period=esc:>
#keybind = alt+shift+comma=esc:<
#keybind = ctrl+alt+f=text:\x1b\x06
#keybind = ctrl+alt+b=text:\x1b\x02

# CSI-u encoded key sequences
# Format: ESC [ <unicode-codepoint> ; <modifier> u
# Modifiers: 2=Shift, 3=Alt, 5=Ctrl, 6=Ctrl+Shift, 7=Ctrl+Alt

# Ctrl key disambiguations (these collide with special keys in traditional encoding)
keybind = ctrl+space=text:\x00
keybind = ctrl+i=text:\x1b[105;5u
keybind = ctrl+m=text:\x1b[109;5u

# Modified Enter (codepoint 13)
keybind = shift+enter=text:\x1b[13;2u
keybind = alt+enter=text:\x1b[13;3u
keybind = ctrl+enter=text:\x1b[13;5u
keybind = ctrl+shift+enter=text:\x1b[13;6u

# Modified Tab (codepoint 9)
keybind = shift+tab=text:\x1b[9;2u
keybind = ctrl+tab=text:\x1b[9;5u
keybind = ctrl+shift+tab=text:\x1b[9;6u

# Modified Backspace (codepoint 127)
keybind = shift+backspace=text:\x1b[127;2u
keybind = ctrl+backspace=text:\x1b[127;5u
keybind = ctrl+shift+backspace=text:\x1b[127;6u

# Modified Escape (codepoint 27)
keybind = shift+escape=text:\x1b[27;2u

# Modified Space (codepoint 32)
keybind = shift+space=text:\x1b[32;2u
keybind = ctrl+shift+space=text:\x1b[32;6u

# Ctrl+Shift+letter (modifier 6)
keybind = ctrl+shift+a=text:\x1b[97;6u
keybind = ctrl+shift+b=text:\x1b[98;6u
keybind = ctrl+shift+c=text:\x1b[99;6u
keybind = ctrl+shift+d=text:\x1b[100;6u
keybind = ctrl+shift+e=text:\x1b[101;6u
keybind = ctrl+shift+f=text:\x1b[102;6u
keybind = ctrl+shift+g=text:\x1b[103;6u
keybind = ctrl+shift+h=text:\x1b[104;6u
keybind = ctrl+shift+i=text:\x1b[105;6u
keybind = ctrl+shift+j=text:\x1b[106;6u
keybind = ctrl+shift+k=text:\x1b[107;6u
keybind = ctrl+shift+l=text:\x1b[108;6u
keybind = ctrl+shift+m=text:\x1b[109;6u
keybind = ctrl+shift+n=text:\x1b[110;6u
keybind = ctrl+shift+o=text:\x1b[111;6u
keybind = ctrl+shift+p=text:\x1b[112;6u
keybind = ctrl+shift+q=text:\x1b[113;6u
keybind = ctrl+shift+r=text:\x1b[114;6u
keybind = ctrl+shift+s=text:\x1b[115;6u
keybind = ctrl+shift+t=text:\x1b[116;6u
keybind = ctrl+shift+u=text:\x1b[117;6u
keybind = ctrl+shift+v=text:\x1b[118;6u
keybind = ctrl+shift+w=text:\x1b[119;6u
keybind = ctrl+shift+x=text:\x1b[120;6u
keybind = ctrl+shift+y=text:\x1b[121;6u
keybind = ctrl+shift+z=text:\x1b[122;6u

# Ctrl+Alt+letter (modifier 7)
keybind = ctrl+alt+a=text:\x1b[97;7u
keybind = ctrl+alt+b=text:\x1b[98;7u
keybind = ctrl+alt+c=text:\x1b[99;7u
keybind = ctrl+alt+d=text:\x1b[100;7u
keybind = ctrl+alt+e=text:\x1b[101;7u
keybind = ctrl+alt+f=text:\x1b[102;7u
keybind = ctrl+alt+g=text:\x1b[103;7u
keybind = ctrl+alt+h=text:\x1b[104;7u
keybind = ctrl+alt+i=text:\x1b[105;7u
keybind = ctrl+alt+j=text:\x1b[106;7u
keybind = ctrl+alt+k=text:\x1b[107;7u
keybind = ctrl+alt+l=text:\x1b[108;7u
keybind = ctrl+alt+m=text:\x1b[109;7u
keybind = ctrl+alt+n=text:\x1b[110;7u
keybind = ctrl+alt+o=text:\x1b[111;7u
keybind = ctrl+alt+p=text:\x1b[112;7u
keybind = ctrl+alt+q=text:\x1b[113;7u
keybind = ctrl+alt+r=text:\x1b[114;7u
keybind = ctrl+alt+s=text:\x1b[115;7u
keybind = ctrl+alt+t=text:\x1b[116;7u
keybind = ctrl+alt+u=text:\x1b[117;7u
keybind = ctrl+alt+v=text:\x1b[118;7u
keybind = ctrl+alt+w=text:\x1b[119;7u
keybind = ctrl+alt+x=text:\x1b[120;7u
keybind = ctrl+alt+y=text:\x1b[121;7u
keybind = ctrl+alt+z=text:\x1b[122;7u

# Ctrl+number (modifier 5)
keybind = ctrl+0=text:\x1b[48;5u
keybind = ctrl+1=text:\x1b[49;5u
keybind = ctrl+2=text:\x1b[50;5u
keybind = ctrl+3=text:\x1b[51;5u
keybind = ctrl+4=text:\x1b[52;5u
keybind = ctrl+5=text:\x1b[53;5u
keybind = ctrl+6=text:\x1b[54;5u
keybind = ctrl+7=text:\x1b[55;5u
keybind = ctrl+8=text:\x1b[56;5u
keybind = ctrl+9=text:\x1b[57;5u

# Ctrl+punctuation (modifier 5)
keybind = ctrl+;=text:\x1b[59;5u
keybind = ctrl+'=text:\x1b[39;5u
keybind = ctrl+,=text:\x1b[44;5u
keybind = ctrl+.=text:\x1b[46;5u
keybind = ctrl+/=text:\x1b[47;5u
keybind = ctrl+-=text:\x1b[45;5u
